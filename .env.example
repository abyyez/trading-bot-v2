# Required — bot will refuse to start without these
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id
BINANCE_API_KEY=your_binance_api_key
BINANCE_API_SECRET=your_binance_api_secret

# Optional
EXECUTION_MODE=PAPER          # PAPER (default) or LIVE
ADMIN_SECRET=                  # Dashboard password — leave empty to disable auth
FLASK_HOST=0.0.0.0             # Dashboard bind address
FLASK_PORT=10000               # Dashboard port
DISABLE_CHARTS=0               # Set to 1 to skip chart rendering (saves RAM on 1GB VPS)
